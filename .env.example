# ─────────────────────────────────────────────────────────────────
# CropSense — Environment Variables
# Copy this file to .env.local for local development with Vercel CLI
# NEVER commit .env.local to git (.gitignore already excludes it)
# ─────────────────────────────────────────────────────────────────

# ── Anthropic Claude API ──────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# Required for: AI diagnosis, chat, alert generation
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── CORS Origin (optional) ────────────────────────────────────────
# Restrict API access to your own domain in production.
# Leave blank to allow all origins (fine for development).
# Example: https://cropsense-new.vercel.app
ALLOWED_ORIGIN=

# ── Vercel (auto-injected — do not set manually) ──────────────────
# VERCEL_URL is automatically set by Vercel on each deployment.
# VERCEL_ENV = production | preview | development
